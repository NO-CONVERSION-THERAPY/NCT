# Site title
# 網站標題
TITLE="N·C·T"

# Default: enable debug mode
# 調試模式
DEBUG_MOD="true"

# Default: disable global maintenance mode
# 停用全域維護模式
MAINTENANCE_MODE="false"

# Optional maintenance notice shown in the Service state panel
# Recommended to write this in the source/original language. English and zh-TW
# pages will use the translation service when it is configured; otherwise the
# original text is shown as a fallback.
# Example: "We are currently rolling out an update. Please check back shortly."
# 服務狀態面板中顯示的選用維護通知
# 建議使用原始語言/原始語言編寫。支援英文和中文（中文-台語）。
# 頁面將在配置翻譯服務後使用翻譯服務；否則，
# 將顯示原始文字作為備用。
# 例如：“我們正在推出更新。請稍後再試。”
MAINTENANCE_NOTICE=""

# Retry-After header value for maintenance responses, in seconds
# 維護回應的 Retry-After 標頭值，以秒為單位
MAINTENANCE_RETRY_AFTER_SECONDS="1800"

# Default: preview submissions without sending them to Google Form
# 預覽提交內容，但不將其傳送至 Google 表單
FORM_DRY_RUN="true"

# Public site URL, used by sitemap.xml and robots.txt
# 公用網站 URL，供 sitemap.xml 和 robots.txt 使用
SITE_URL="https://www.victimsunion.org/"

# HTTP port
PORT="3000"

# Page read rate limit: max page requests within 5 minutes per client IP
# 頁面讀取速率限制：每個客戶端 IP 在 5 分鐘內的最大頁面請求次數
PAGE_READ_RATE_LIMIT_MAX="180"

# Public map API read rate limit: max map-data requests within 5 minutes per client IP
# 公共地圖 API 讀取速率限制：每個客戶端 IP 在 5 分鐘內最多可進行 5 分鐘的地圖資料請求
MAP_READ_RATE_LIMIT_MAX="60"

# Submission rate limit: max submissions within 15 minutes per client IP
# 提交速率限制：每個客戶端 IP 在 15 分鐘內最多提交次數
SUBMIT_RATE_LIMIT_MAX="5"

# Form protection signing secret
# Generate one with: npm run secure-config -- generate-secret
# 表單保護簽署金鑰
# 使用下列指令產生金鑰：npm run secure-config -- generate-secret
FORM_PROTECTION_SECRET="replace-this-with-a-long-random-secret"

# Minimum time required before a form can be submitted, in milliseconds
# 表單提交所需的最短等待時間（毫秒）
FORM_PROTECTION_MIN_FILL_MS="3000"

# Maximum age of a form protection token, in milliseconds
# 表單保護令牌的最大有效期，以毫秒為單位
FORM_PROTECTION_MAX_AGE_MS="86400000"

# Google Form ID
# Prefer storing the plain value in a Secret manager, or use FORM_ID_ENCRYPTED below.
# If FORM_ID_ENCRYPTED is used, FORM_PROTECTION_SECRET must be explicitly configured.
# Google 表單 ID
# 建議將明文值儲存在金鑰管理員中，或使用下方的 FORM_ID_ENCRYPTED。
# 如果使用 FORM_ID_ENCRYPTED，則必須明確配置 FORM_PROTECTION_SECRET。
FORM_ID=""

# Encrypted Google Form ID generated with:
# npm run secure-config -- encrypt --purpose form-id --secret "your-FORM_PROTECTION_SECRET" --value "your-Google-Form-ID"
# 使用以下命令產生加密的 Google 表單 ID：
# npm run secure-config -- encrypt --purpose form-id --secret "your-FORM_PROTECTION_SECRET" --value "your-Google-Form-ID"
FORM_ID_ENCRYPTED=""

# Google Apps Script API URL
# Set this if you have your own Apps Script data source.
# Prefer storing the plain value in a Secret manager, or use GOOGLE_SCRIPT_URL_ENCRYPTED below.
# 如果您有自己的 Apps Script 資料來源，請設定此項目。
# 建議將明文值儲存在 Secret 管理器中，或使用下面的 GOOGLE_SCRIPT_URL_ENCRYPTED。
GOOGLE_SCRIPT_URL=""

# Encrypted Google Apps Script API URL generated with:
# 使用以下命令產生加密的 Google Apps Script API URL：
# npm run secure-config -- encrypt --purpose google-script-url --secret "your-FORM_PROTECTION_SECRET" --value "your-Google-Script-URL"
GOOGLE_SCRIPT_URL_ENCRYPTED=""

# Public map data API
# If self-hosting without a private Apps Script source, this can point to your own public map API
# 如果採用自託管方式且沒有私人 Apps Script 來源，則可以將其指向您自己的公用地圖 API
PUBLIC_MAP_DATA_URL="https://your-domain.example/api/map-data"

# Optional: enable Node-only transport overrides for map-data upstream requests
# When true, proxy-agent and IPv4 direct fallback are both allowed; default is off
# Cloudflare Workers runtime ignores this flag
# 可選：啟用僅限節點的 map-data 上游請求傳輸覆蓋
# 啟用後，代理程式和 IPv4 直接回退均被允許；預設為關閉
# Cloudflare Workers 執行時期會忽略此標誌
MAP_DATA_NODE_TRANSPORT_OVERRIDES="false"

# Optional: upstream timeout for map-data requests in milliseconds
# Increase this if your public map-data source is consistently slow
# 可選：上游地圖資料請求逾時時間（毫秒）
# 如果您的公共地圖資料來源持續運作緩慢，請增加此值。
MAP_DATA_UPSTREAM_TIMEOUT_MS="25000"

# Official Google Cloud Translation API
# Create an API key in Google Cloud Console after enabling Cloud Translation API.
# This project only supports Google Cloud Translation as the runtime provider.
# 啟用 Cloud Translation API 後，請在 Google Cloud Console 中建立 API 金鑰。
# 此專案僅支援 Google Cloud Translation 作為運行時提供者。
GOOGLE_CLOUD_TRANSLATION_API_KEY="replace-with-your-google-cloud-translation-api-key"

# Translation request timeout in milliseconds
# Increase this only if Google Cloud Translation is consistently slow.
# 翻譯請求超時時間（毫秒）
# 僅當 Google 雲端翻譯持續運作緩慢時才增加此值。
TRANSLATION_PROVIDER_TIMEOUT_MS="10000"

# Default: trust reverse proxy headers
# 預設值：信任反向代理標頭
TRUST_PROXY="true"

# Recommended for multi-instance deployments so rate limits are shared
# Leave empty if you only run a single app instance.
# When empty, the app falls back to in-memory rate limiting:
# - works on a single instance
# - resets when the app restarts
# - does not share limits across multiple instances
# TLS example: rediss://default:password@host:6379
# 建議在多執行個體部署中使用，以便共用速率限制
# 如果只執行單一應用實例，請留空。
# 如果留空，應用程式將回退到記憶體速率限制：
# - 僅適用於單一實例
# - 應用重新啟動後重置
# - 多個實例之間不共用限制
# TLS 範例：r​​ediss://default:password@host:6379
RATE_LIMIT_REDIS_URL="rediss://default:password@your-redis-host:6379"
