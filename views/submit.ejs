<!DOCTYPE html>
<html lang="<%= lang %>">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title><%= t('common.siteName') %></title>
        <link rel="stylesheet" href="/css/index.css">
        <script>
            window.APP_LANG = "<%= lang %>";
            window.I18N = <%- JSON.stringify(clientMessages) %>;
        </script>
    </head>
    <body>
        <%- include('partials/language_switcher') %>

        <div class="hero">
            <h1><%= t('submitSuccess.title') %></h1>
            <p>
                <%= t('submitSuccess.message') %>
            </p>
            <a href="/" class="btn"><%= t('submitSuccess.backHome') %></a>
            <a href="https://github.com/HosinoEJ/No-Torsion" class="btn"><%= t('submitSuccess.petition') %></a>
        </div>

        <div class="footer">
            <%= t('common.footerBy') %><a href="https://github.com/HosinoEJ">HosinoNeko</a>
        </div>
        <%- include('partials/foot') %>
    </body>
</html>
