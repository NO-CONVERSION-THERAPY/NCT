<%- include('partials/head') %>
<html>
<head>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <style>
        body > * {
            width: 70%;
        }
    </style>
</head>
<body>
    <%- include('partials/language_switcher') %>
    <h1><%= t('map.title') %></h1>
    <p><a href="/"><%= t('navigation.home') %></a></p>
    <h3><%= t('map.sections.stats') %></h3>
    <%- include('partials/map_allnum') %>
    <h3><%= t('map.sections.tags') %></h3>
    <%- include('partials/map_tag') %>
