<!DOCTYPE html>
<html lang="<%= lang %>">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title><%= title %></title>
        <link rel="stylesheet" href="/css/main.css">
        <script>
            window.APP_LANG = "<%= lang %>";
            window.I18N = <%- JSON.stringify(clientMessages) %>;
        </script>
        <style>
            body {
                padding: 2rem 1rem 4rem;
            }
            .preview-container {
                max-width: 960px;
                margin: 0 auto;
            }
            .preview-table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 1.5rem;
                background: #fff;
            }
            .preview-table th,
            .preview-table td {
                border: 1px solid #ddd;
                padding: 0.75rem;
                text-align: left;
                vertical-align: top;
            }
            .preview-table th {
                background: #f5f5f5;
            }
            pre {
                white-space: pre-wrap;
                word-break: break-all;
                background: #111;
                color: #f5f5f5;
                padding: 1rem;
                border-radius: 8px;
            }
        </style>
    </head>
    <body>
        <%- include('partials/language_switcher') %>
        <div class="preview-container">
            <h1><%= t('submitPreview.title') %></h1>
            <p><%= t('submitPreview.intro') %></p>
            <p><strong><%= t('submitPreview.targetUrl') %></strong> <code><%= googleFormUrl %></code></p>
            <table class="preview-table">
                <thead>
                    <tr>
                        <th><%= t('submitPreview.columns.entry') %></th>
                        <th><%= t('submitPreview.columns.field') %></th>
                        <th><%= t('submitPreview.columns.value') %></th>
                    </tr>
                </thead>
                <tbody>
                    <% fields.forEach((field) => { %>
                        <tr>
                            <td><code><%= field.entryId %></code></td>
                            <td><%= field.label %></td>
                            <td><%= field.value %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>

            <h2><%= t('submitPreview.payload') %></h2>
            <pre><%= encodedPayload %></pre>

            <p><a href="/form"><%= t('submitPreview.backForm') %></a></p>
        </div>
        <%- include('partials/foot') %>
    </body>
</html>
